# Binary (top-level only, not cmd/rd/)
/rd
*.exe

# Campfire local state
.campfire/

# Claude Code — agent specs, project instructions, worktrees
.claude/
CLAUDE.md

# Telemetry
.telemetry/

# Internal docs
docs/migration-brief.md
docs/resonant/

# Local state (not committed)
.cf/
.ready/
# rd home marker for per-worktree nostr identity isolation ($RD_HOME walk-up).
# Also holds the nostr signing secret when a repo-local rd home is used, so it
# must never be committed (defense-in-depth: the key-path guard also refuses to
# write the secret to any path inside a git work tree that is not ignored).
.rd/
cover.out

# Nostr portfolio signing key (secret material). Named explicitly for
# defense-in-depth on top of the .cf/ blanket ignore above — this file must
# never be tracked no matter where it ends up on disk.
nostr-identity.json

# Local vendor tree (generated on demand for offline builds; never committed)
/vendor/
