{
  "convention": "work",
  "version": "0.4",
  "operation": "label-add",
  "description": "Add a label to an existing work item",
  "args": [
    {"name": "id", "type": "string", "required": true, "max_length": 64, "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    {"name": "label", "type": "string", "required": true, "max_length": 32, "pattern": "^[a-z0-9][a-z0-9-]{0,31}$"}
  ],
  "produces_tags": [
    {"tag": "work:label-add", "cardinality": "exactly_one"}
  ],
  "antecedents": "none",
  "signing": "member_key"
}
