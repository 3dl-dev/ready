{"msg_id":"37f8e6d9-3c39-4190-b5e2-a60e3707fcf4","campfire_id":"670f815159f88220981e79b7cbbc5e98432d73771c215b7d2082ec818b74329a","timestamp":1775664377801931932,"operation":"work:close","payload":{"reason":"Implemented: e2e smoke test for new-install ~/.cf path validates full workflow (init, create, list, show). PR: https://github.com/campfire-net/ready/pull/14","resolution":"done","target":"f2dfbd59-6121-4749-be0a-87c005843da3"},"tags":["work:close"],"sender":"1e224c14bc7959bf6bec7d4e563389b6c3d3e9255ad206df1ba60cdc52197ffd"}
