{"msg_id":"54051a81-7a8d-452c-988a-c9292c90a847","campfire_id":"670f815159f88220981e79b7cbbc5e98432d73771c215b7d2082ec818b74329a","timestamp":1775690887818146175,"operation":"work:close","payload":{"reason":"Suppressed inbox campfire membership warning for non-owners by guarding WithInboxCampfireID with a GetMembership check in requireConventionServer(). Regression test in cmd/rd/convention_server_test.go verifies no warning appears for non-member clients. PR: https://github.com/campfire-net/ready/pull/41","resolution":"done","target":"2e9ef1d0-3706-4bf5-9d79-efba506037a7"},"tags":["work:close"],"sender":"1e224c14bc7959bf6bec7d4e563389b6c3d3e9255ad206df1ba60cdc52197ffd"}
{"msg_id":"dab7582d-0bef-44d3-b008-e5234ff755c7","campfire_id":"670f815159f88220981e79b7cbbc5e98432d73771c215b7d2082ec818b74329a","timestamp":1775690984693858368,"operation":"work:close","payload":{"reason":"Implemented isRemoteTransport() to detect local vs hosted transport via remote.json in CF_HOME. Local filesystem campfires skip durability evaluation (MeetsMinimum=true, no warnings). Hosted campfires retain full durability check. 4 new tests, all passing. PR #42 open.","resolution":"done","target":"62b62c10-ef40-49a6-931f-8eab8d6e6e16"},"tags":["work:close"],"sender":"1e224c14bc7959bf6bec7d4e563389b6c3d3e9255ad206df1ba60cdc52197ffd"}
